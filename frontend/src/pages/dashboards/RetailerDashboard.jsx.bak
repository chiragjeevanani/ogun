            <div className="md:hidden fixed left-0 top-16 sm:top-20 z-40 h-[calc(100vh-4rem)] sm:h-[calc(100vh-5rem)] w-64 bg-gradient-to-b from-gray-900/95 via-gray-900 to-black shadow-2xl flex flex-col overflow-hidden">
              <div className="text-center py-4 px-2 border-b border-white/20 flex-shrink-0">
                <h2 className="text-white font-bold text-lg">🏪 Retailer</h2>
              </div>
              <nav className="flex-1 w-full space-y-1 p-2 overflow-y-auto scrollbar-thin scrollbar-thumb-gray-700 scrollbar-track-gray-900">
