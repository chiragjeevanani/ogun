import React, { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import ResponsiveSidebar from '../../components/admin/ResponsiveSidebar';

const RetailerDashboard = () => {
  const navigate = useNavigate();
  const [activeSection, setActiveSection] = useState('dashboard');
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [userName] = useState(() => {
    const data = JSON.parse(localStorage.getItem('loginData') || '{}');
    return data.userName || 'Retailer';
  });

  const handleLogout = () => {
    localStorage.removeItem('loginData');
    navigate('/login');
  };

  const retailerMenuItems = [
    { id: 'dashboard', icon: '📊', label: 'Dashboard' },
    { id: 'store', icon: '🏪', label: 'Store' },
    { id: 'inventory', icon: '📦', label: 'Inventory' },
    { id: 'sales', icon: '💳', label: 'Sales' },
    { id: 'customers', icon: '👥', label: 'Customers' },
    { id: 'settings', icon: '⚙️', label: 'Settings' },
  ];

  const stats = [
    { label: 'Shop Stock', value: '456', icon: '🏪', gradient: 'from-orange-500 to-orange-700' },
    { label: 'Daily Sales', value: '₹45K', icon: '💳', gradient: 'from-green-500 to-green-700' },
    { label: 'Customers Today', value: '123', icon: '👥', gradient: 'from-blue-500 to-blue-700' },
    { label: 'Pending Orders', value: '12', icon: '📦', gradient: 'from-pink-500 to-pink-700' },
  ];

  const storeInfo = [
    { label: 'Store Name', value: 'Premium Kitchen Store' },
    { label: 'Location', value: 'Sector 7, Mumbai' },
    { label: 'Contact', value: '+91-9876-543-210' },
    { label: 'Join Date', value: '15 Jan 2024' },
  ];

  const topProducts = [
    { id: 1, name: 'Stainless Steel Cookware Set', sold: 234, revenue: '₹1.2L' },
    { id: 2, name: 'Premium Chef Knife', sold: 156, revenue: '₹2.1L' },
    { id: 3, name: 'Smart Electric Kettle', sold: 189, revenue: '₹1.8L' },
    { id: 4, name: 'Non-Stick Cookware', sold: 145, revenue: '₹1.5L' },
    { id: 5, name: 'Digital Food Scale', sold: 198, revenue: '₹1.9L' },
  ];

  const inventoryList = [
    { id: 1, name: 'Stainless Steel Cookware Set', stock: 45, minStock: 20, status: '✓ Good' },
    { id: 2, name: 'Premium Chef Knife Collection', stock: 12, minStock: 15, status: '⚠ Low' },
    { id: 3, name: 'Smart Electric Kettle Pro', stock: 32, minStock: 25, status: '✓ Good' },
    { id: 4, name: 'Non-Stick Cookware Set', stock: 28, minStock: 20, status: '✓ Good' },
    { id: 5, name: 'Digital Food Scale', stock: 56, minStock: 30, status: '✓ Good' },
  ];

  const salesData = [
    { date: '2026-03-28', transactions: 45, revenue: '₹38K', avgOrder: '₹845' },
    { date: '2026-03-29', transactions: 52, revenue: '₹42K', avgOrder: '₹808' },
    { date: '2026-03-30', transactions: 38, revenue: '₹35K', avgOrder: '₹921' },
    { date: '2026-03-31', transactions: 61, revenue: '₹51K', avgOrder: '₹836' },
    { date: '2026-04-01', transactions: 48, revenue: '₹45K', avgOrder: '₹938' },
  ];

  const customersData = [
    { id: 1, name: 'Rahul Kumar', email: 'rahul@email.com', phone: '9876-543-210', purchases: 12, totalSpent: '₹45K' },
    { id: 2, name: 'Priya Singh', email: 'priya@email.com', phone: '9876-543-211', purchases: 8, totalSpent: '₹32K' },
    { id: 3, name: 'Amit Patel', email: 'amit@email.com', phone: '9876-543-212', purchases: 15, totalSpent: '₹62K' },
    { id: 4, name: 'Neha Sharma', email: 'neha@email.com', phone: '9876-543-213', purchases: 6, totalSpent: '₹28K' },
    { id: 5, name: 'Vikram Desai', email: 'vikram@email.com', phone: '9876-543-214', purchases: 10, totalSpent: '₹52K' },
