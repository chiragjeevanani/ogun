                  <button
                    key={item.id}
                    onClick={() => {
                      setActiveSection(item.id);
                      setSidebarOpen(false);
                    }}
                    className={`w-full flex items-center gap-2 px-3 py-2 rounded-lg transition-all duration-200 text-xs flex-shrink-0 ${
                      activeSection === item.id
                        ? 'bg-green-500/20 text-green-400 shadow-lg'
                        : 'text-gray-300 hover:bg-gray-800'
                    }`}
                  >
                    <span className="text-base flex-shrink-0">{item.icon}</span>
                    <span className="text-white font-semibold truncate text-xs">{item.label}</span>
                  </button>
                ))}
              </nav>
              <div className="p-2 border-t border-white/20 flex-shrink-0">
                <button onClick={handleLogout} className="w-full flex items-center gap-3 px-3 py-2 rounded text-red-400 hover:bg-red-500/10 transition-all duration-200 text-left font-medium text-xs">
                  <span className="text-lg flex-shrink-0">🚪</span>
                  <span>Logout</span>
                </button>
              </div>
            </div>
          </>
        )}

        {/* Main Content */}
        <div className="flex-1 w-full overflow-auto bg-white pb-6 sm:pb-8">
          <div className="p-3 sm:p-4 md:p-6 lg:p-8 space-y-4 sm:space-y-6 md:space-y-8 min-h-full">
            {/* Only show header and stats on dashboard */}
            {activeSection === 'dashboard' && (
              <>
                <div>
                  <h2 className="text-lg sm:text-2xl md:text-3xl font-bold text-black">📊 Retailer Dashboard</h2>
                  <p className="text-gray-600 text-xs sm:text-sm mt-1">Manage your retail store</p>
                </div>

                <div className="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
                  {stats.map((stat, idx) => (
                    <div key={idx} className={`bg-gradient-to-br ${stat.gradient} rounded-xl p-3 sm:p-4 text-white shadow-lg hover:shadow-xl transition-all`}>
                      <div className="text-lg sm:text-2xl md:text-3xl mb-2">{stat.icon}</div>
                      <p className="text-white/80 text-xs sm:text-sm font-medium mb-1">{stat.label}</p>
                      <p className="text-lg sm:text-2xl md:text-3xl font-bold">{stat.value}</p>
                    </div>
                  ))}
                </div>
              </>
            )}

            {/* Dynamic Content */}
            {renderContent()}
          </div>
        </div>
      </div>
    </div>
