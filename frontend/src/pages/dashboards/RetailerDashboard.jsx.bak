              <table className="w-full text-xs sm:text-sm">
                <thead className="bg-gray-200 border-b border-gray-300">
                  <tr>
                    <th className="px-2 sm:px-4 py-2 text-left font-semibold text-gray-700">Name</th>
                    <th className="hidden sm:table-cell px-2 sm:px-4 py-2 text-left font-semibold text-gray-700">Email</th>
                    <th className="hidden md:table-cell px-2 sm:px-4 py-2 text-center font-semibold text-gray-700">Purchases</th>
                    <th className="px-2 sm:px-4 py-2 text-right font-semibold text-gray-700">Total Spent</th>
                  </tr>
                </thead>
                <tbody>
                  {customersData.map((customer, idx) => (
                    <tr key={idx} className="border-b border-gray-200 hover:bg-gray-100 transition-all">
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-gray-700 font-medium truncate">{customer.name}</td>
                      <td className="hidden sm:table-cell px-2 sm:px-4 py-2.5 sm:py-3 text-gray-600 truncate text-xs sm:text-sm">{customer.email}</td>
                      <td className="hidden md:table-cell px-2 sm:px-4 py-2.5 sm:py-3 text-center text-gray-700 font-semibold">{customer.purchases}</td>
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-right text-green-600 font-bold">{customer.totalSpent}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
