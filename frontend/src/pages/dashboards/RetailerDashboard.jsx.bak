            </div>

            <div className="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl border border-gray-200 p-3 sm:p-6 shadow-sm overflow-x-auto">
              <h3 className="text-base sm:text-lg md:text-xl font-bold text-black mb-3 sm:mb-4">🔥 Top Selling Products</h3>
              <table className="w-full text-xs sm:text-sm">
                <thead className="bg-gray-200 border-b border-gray-300">
                  <tr>
                    <th className="px-2 sm:px-4 py-2 text-left font-semibold text-gray-700">Product Name</th>
                    <th className="px-2 sm:px-4 py-2 text-center font-semibold text-gray-700">Sold</th>
                    <th className="hidden md:table-cell px-2 sm:px-4 py-2 text-right font-semibold text-gray-700">Revenue</th>
                  </tr>
                </thead>
                <tbody>
                  {topProducts.map((product, idx) => (
                    <tr key={idx} className="border-b border-gray-200 hover:bg-gray-100 transition-all">
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-gray-700 font-medium truncate">{product.name}</td>
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-center text-gray-700 font-bold">{product.sold}</td>
                      <td className="hidden md:table-cell px-2 sm:px-4 py-2.5 sm:py-3 text-right text-green-600 font-bold">{product.revenue}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        );

      case 'store':
        return (
