              <table className="w-full text-xs sm:text-sm">
                <thead className="bg-gray-200 border-b border-gray-300">
                  <tr>
                    <th className="px-2 sm:px-4 py-2 text-left font-semibold text-gray-700">Product Name</th>
                    <th className="px-2 sm:px-4 py-2 text-center font-semibold text-gray-700">Stock</th>
                    <th className="hidden md:table-cell px-2 sm:px-4 py-2 text-center font-semibold text-gray-700">Min Stock</th>
                    <th className="px-2 sm:px-4 py-2 text-center font-semibold text-gray-700">Status</th>
                  </tr>
                </thead>
                <tbody>
                  {inventoryList.map((item, idx) => (
                    <tr key={idx} className="border-b border-gray-200 hover:bg-gray-100 transition-all">
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-gray-700 font-medium truncate">{item.name}</td>
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-center text-gray-700 font-bold">{item.stock}</td>
                      <td className="hidden md:table-cell px-2 sm:px-4 py-2.5 sm:py-3 text-center text-gray-600">{item.minStock}</td>
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-center">
                        <span className={`px-2 sm:px-3 py-1 rounded-lg text-xs font-semibold ${
                          item.status.includes('Low') ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'
                        }`}>
                          {item.status}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        );

      case 'sales':
        return (
          <div className="space-y-6">
            <h2 className="text-lg sm:text-2xl md:text-3xl font-bold text-black">💳 Sales Report</h2>
            <div className="grid grid-cols-1 md:grid-cols-4 gap-3 sm:gap-4">
              <div className="bg-gradient-to-br from-green-50 to-green-100 rounded-xl border border-green-200 p-3 sm:p-4">
                <p className="text-green-700 text-xs font-semibold mb-1">Total Sales (Today)</p>
                <p className="text-2xl sm:text-3xl font-bold text-green-900">₹45K</p>
              </div>
              <div className="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl border border-blue-200 p-3 sm:p-4">
                <p className="text-blue-700 text-xs font-semibold mb-1">Transactions</p>
                <p className="text-2xl sm:text-3xl font-bold text-blue-900">48</p>
              </div>
              <div className="bg-gradient-to-br from-orange-50 to-orange-100 rounded-xl border border-orange-200 p-3 sm:p-4">
                <p className="text-orange-700 text-xs font-semibold mb-1">Avg Order Value</p>
                <p className="text-2xl sm:text-3xl font-bold text-orange-900">₹938</p>
              </div>
              <div className="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl border border-purple-200 p-3 sm:p-4">
                <p className="text-purple-700 text-xs font-semibold mb-1">Monthly Total</p>
                <p className="text-2xl sm:text-3xl font-bold text-purple-900">₹2.3L</p>
              </div>
            </div>
            <div className="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl border border-gray-200 p-3 sm:p-6 shadow-sm overflow-x-auto">
              <table className="w-full text-xs sm:text-sm">
                <thead className="bg-gray-200 border-b border-gray-300">
                  <tr>
                    <th className="px-2 sm:px-4 py-2 text-left font-semibold text-gray-700">Date</th>
                    <th className="px-2 sm:px-4 py-2 text-center font-semibold text-gray-700">Transactions</th>
                    <th className="hidden md:table-cell px-2 sm:px-4 py-2 text-right font-semibold text-gray-700">Revenue</th>
                    <th className="hidden lg:table-cell px-2 sm:px-4 py-2 text-right font-semibold text-gray-700">Avg Order</th>
                  </tr>
                </thead>
                <tbody>
                  {salesData.map((sale, idx) => (
                    <tr key={idx} className="border-b border-gray-200 hover:bg-gray-100 transition-all">
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-gray-700 font-medium">{sale.date}</td>
                      <td className="px-2 sm:px-4 py-2.5 sm:py-3 text-center text-gray-700 font-bold">{sale.transactions}</td>
                      <td className="hidden md:table-cell px-2 sm:px-4 py-2.5 sm:py-3 text-right text-green-600 font-bold">{sale.revenue}</td>
                      <td className="hidden lg:table-cell px-2 sm:px-4 py-2.5 sm:py-3 text-right text-gray-700 font-semibold">{sale.avgOrder}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        );

      case 'customers':
        return (
          <div className="space-y-6">
            <h2 className="text-lg sm:text-2xl md:text-3xl font-bold text-black">👥 Customers</h2>
